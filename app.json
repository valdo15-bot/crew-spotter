{
  "expo": {
    "name": "Crew Spotter",
    "slug": "crew-spotter",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#1C2130"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "es.smarting.crewspotter",
      "userInterfaceStyle": "dark"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1C2130"
      },
      "package": "es.smarting.crewspotter",
      "userInterfaceStyle": "dark"
    },
    "web": {
      "bundler": "metro"
    },
    "assetBundlePatterns": ["**/*"],
    "plugins": ["expo-font"]
  }
}
